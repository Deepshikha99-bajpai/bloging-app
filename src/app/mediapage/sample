.container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 1rem;
}

.infoContainer {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 1rem;
  margin-bottom: 2rem;
}

.textContainer {
  flex: 1;
  text-align: center;
}

.user {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  margin-left: 1rem;
}

.userImageContainer {
  flex-shrink: 0;
}

.avatar {
  border-radius: 50%;
  width: 80px;
  height: 80px;
}

.userTextContainer {
  display: flex;
  flex-direction: column;
  text-align: center;
}

.username {
  font-weight: bold;
  font-size: 1.1rem;
}

.date {
  font-size: 0.9rem;
  color: #666;
}

.speechFloating {
  position: static;
  margin-top: 1rem;
}


.heroImage {
  position: relative;
  width: 100%;
  height: 350px; /* Adjust height as needed */
  margin: 2rem 0; /* space above and below image */
  border-radius: 12px;
  overflow: hidden;
}

.image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.section {
  margin-bottom: 2rem;
}

.space {
  padding-top: 1.5rem;
  border-top: 1px solid #eee;
}

.content {
  display: flex;
  gap: 2rem;
  margin-top: 2rem;
}

.post {
  flex: 3;
}

.sidebar {
  flex: 1;
}

.subSection {
  margin-top: 25px;
  margin-bottom: 50px; /* 👈 adds spacing between course, faculty, event */
  line-height: 1.9em;
}

.sectionContent {
  margin-top: 1rem;
}

.sectionContent p {
  margin-bottom: 12px;
}

.feedbackInput {
  margin-top: 15px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.feedbackInput textarea {
  width: 100%;
  min-height: 80px;
  padding: 10px;
  border-radius: 10px;
  border: 1px solid #ccc;
  resize: vertical;
  font-size: 14px;
}

.feedbackInput button {
  align-self: flex-end;
  padding: 8px 16px;
  border-radius: 8px;
  border: none;
  background-color: #0070f3;
  color: #fff;
  cursor: pointer;
}

.feedbackList {
  margin-top: 15px;
  padding-left: 20px;
}

.feedbackList li {
  margin-bottom: 8px;
  background: #f9f9f9;
  padding: 8px;
  border-radius: 6px;
}

.buttonGroup {
  display: flex;
  gap: 20px; /* Increases space between buttons */
  justify-content: start;
  margin-top: 10px;
}

.buttonGroup button {
  padding: 12px 24px; /* Increases button size */
  font-size: 1.1rem;   /* Slightly larger text */
  border-radius: 12px; /* Rounded corners */
  border: none;
  background-color: #95c3e4;
  color: black;
  cursor: pointer;
  transition: background-color 0.3s ease;
}

.buttonGroup button:hover {
  background-color: #909eac;
}

.comment {
  margin-top: 2rem;
}
